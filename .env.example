# Postgres (Supabase or local via docker-compose)
DATABASE_URL="postgresql://badgehunters:badgehunters@localhost:5432/badgehunters?schema=public"
DATABASE_URL_UNPOOLED="postgresql://badgehunters:badgehunters@localhost:5432/badgehunters?schema=public"

# Auth.js / NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-random-string"
AUTH_URL="http://localhost:3000"

# Google OAuth (required for real users; not needed if only using admin mode locally)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# First Google user with this email becomes superuser on login (Spec §4)
SUPERUSER_EMAIL="kyle.murray100@gmail.com"

# Admin mode password (Spec §5, §17). Grants access to test-user tooling and dev cheats.
# This is NOT a user account — it activates admin mode for the browser session.
ADMIN_MODE_PASSWORD=""

# Browserless.io token for PlayActivate lookups in production.
# When set, puppeteer connects to Browserless instead of launching local Chromium.
# Not needed for local dev (uses your local Chrome). Get a token at browserless.io.
BROWSERLESS_TOKEN=""
